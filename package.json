{
  "name": "flow",
  "displayName": "Flow - Tab Manager",
  "version": "1.2.9",
  "description": "A new way to manage chrome tabs and windows easily.",
  "author": "Mahdi Mallaee",
"packageManager": "pnpm@8.10.3",
  "scripts": {
    "dev": "plasmo dev --hoist",
    "build": "plasmo build --hoist",
    "package": "plasmo package",
    "firefox": "plasmo build --target=firefox-mv3 --hoist"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "motion": "^12.40.0",
    "plasmo": "0.90.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0",
    "uuid": "^14.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "3.6.4",
    "@types/chrome": "^0.1.43",
    "@types/node": "25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.3",
    "prettier": "3.8.4",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3"
  },
  "manifest": {
    "browser_specific_settings": {
      "gecko": {
        "id": "@flow-tab-manager",
        "strict_min_version": "109.0"
      }
    },
    "permissions": [
      "storage",
      "tabs",
      "tabGroups",
      "unlimitedStorage",
      "favicon",
      "contextMenus"
    ],
    "optional_permissions": [
      "history",
      "downloads",
      "system.display"
    ]
  }
}
