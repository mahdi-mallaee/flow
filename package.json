{
  "name": "flow",
  "displayName": "Flow - Tab Manager",
  "version": "1.2.9",
  "description": "A new way to manage chrome tabs and windows easily.",
  "author": "Mahdi Mallaee",
  "packageManager": "npm@9.1.3",
  "scripts": {
    "dev": "plasmo dev --hoist",
    "build": "plasmo build --hoist",
    "package": "plasmo package",
    "firefox": "plasmo build --target=firefox-mv3 --hoist"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.6.1",
    "motion": "^12.40.0",
    "plasmo": "0.74.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.15.0",
    "uuid": "^9.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "3.6.4",
    "@types/chrome": "^0.0.266",
    "@types/node": "20.2.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.3",
    "prettier": "2.8.8",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3"
  },
  "manifest": {
    "browser_specific_settings": {
      "gecko": {
        "id": "@flow-tab-manager",
        "strict_min_version": "109.0"
      }
    },
    "permissions": [
      "storage",
      "tabs",
      "tabGroups",
      "unlimitedStorage",
      "favicon",
      "contextMenus"
    ],
    "optional_permissions": [
      "history",
      "downloads",
      "system.display"
    ]
  }
}
